---
import {
  ArrowRight,
  CalendarCheck2,
  CircleAlert,
  CircleCheck,
  Flag,
  FileCheck2,
  Search,
  ShieldCheck,
  Target,
  UserRoundCheck,
} from '@lucide/astro/icons';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentMeta from '../components/ContentMeta.astro';
import eeatReportData from '../../reports/eeat-inventory.json';
import qualityWorkbookData from '../../reports/quality-workbook.json';
import searchConsolePlanData from '../../reports/search-console-priority.json';
import {
  EDITORIAL_LINKS,
  HIGH_RISK_TOPIC_SLUGS,
  SITE_LAUNCH_DATE,
} from '../data/editorial';
import { federalSources, getStatePublicStatus, states, topics } from '../data/content';

type ReviewStatus = 'human-approved' | 'ai-assisted' | 'source-mapped' | 'pending' | 'invalid' | 'not-required';
type Risk = 'standard' | 'medium' | 'high' | 'policy';
type PageType = 'state-overview' | 'state-real-id' | 'topic' | 'directory' | 'collection' | 'trust';

type SemanticReview = {
  reviewedAt?: string;
  reviewer?: string;
  scope?: string;
  notes?: string;
};

type EeatPage = {
  route: string;
  pageType: PageType;
  risk: Risk;
  score: number;
  threshold: number;
  pass: boolean;
  indexable: boolean;
  reviewStatus: ReviewStatus;
  reviewMethod: 'ai-assisted' | 'human' | 'automated' | null;
  semanticReview: SemanticReview | null;
  signals: {
    sourceCount: number;
    factCheckCount: number;
    hasFactMapping: boolean;
    hasInlineStateEvidence: boolean;
    hasInlineDirectoryEvidence: boolean;
    hasEditorialDisclosure: boolean;
    visibleThreeDates: boolean;
    authorLink: boolean;
    schemaAuthorUrl: boolean;
    stateEvidenceItems: number;
    directoryEvidenceItems: number;
  };
  critical: string[];
  blockers: string[];
};

type EeatSummary = {
  generatedAt: string;
  pages: number;
  passed: number;
  indexablePages: number;
  noindexPages: number;
  indexablePassed: number;
  blockedPages: number;
  threshold: number;
  highRiskHumanApprovalPending: number;
  aiAssistedReviews: number;
  humanApprovedReviews: number;
  sourceMappedReviews: number;
  evidenceReviewPending: number;
  belowThreshold: number;
  averageScore: number;
  strict: boolean;
  criticalPages: number;
};

type WorkbookTask = {
  route: string;
  risk: string;
  score: number;
  reviewStatus: string;
  reviewDue?: string;
  priority?: string;
  action?: string;
  actionMethod?: string;
  expectedOutcome?: string;
  blockersCount?: number;
  criticalCount?: number;
  reviewer?: string;
  notes?: string;
};

type SearchConsoleAction = {
  route: string;
  action: string;
  impressionsCurrent: number;
  clicksCurrent: number;
  ctrCurrent: number;
  positionCurrent: number;
  impressionsDelta: number;
  reason: string;
};

type WorkbookReport = {
  summary?: {
    blockedPages?: number;
    highRiskPending?: number;
    pages?: number;
    byType?: Record<string, number>;
    byRisk?: Record<string, number>;
  };
  queues?: {
    humanSignoff?: WorkbookTask[];
    blocked?: WorkbookTask[];
    intentFixes?: WorkbookTask[];
  };
  generatedAt?: string;
};

type SearchConsoleReport = {
  prioritized?: SearchConsoleAction[];
  actions?: {
    improveTitle?: SearchConsoleAction[];
    improveAnswer?: SearchConsoleAction[];
    refreshRule?: SearchConsoleAction[];
    newTopics?: SearchConsoleAction[];
  };
  totalRows?: number;
  includedRows?: number;
  source?: string;
};

type EeatReport = {
  summary: EeatSummary;
  pages: EeatPage[];
};

const QUALITY_MODIFIED_AT = '2026-07-21';
const QUALITY_REVIEWED_AT = '2026-07-21';
const today = QUALITY_REVIEWED_AT;
const toIsoDate = (offsetDays: number) =>
  new Date(Date.parse(today) + offsetDays * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);

const stateById = new Map(states.map((state) => [state.id, state]));
const topicBySlug = new Map(topics.map((topic) => [topic.slug, topic]));

const defaultSummary: EeatSummary = {
  generatedAt: '',
  pages: 0,
  passed: 0,
  indexablePages: 0,
  noindexPages: 0,
  indexablePassed: 0,
  blockedPages: 0,
  threshold: 85,
  highRiskHumanApprovalPending: 0,
  aiAssistedReviews: 0,
  humanApprovedReviews: 0,
  sourceMappedReviews: 0,
  evidenceReviewPending: 0,
  belowThreshold: 0,
  averageScore: 0,
  strict: false,
  criticalPages: 0,
};

const report = eeatReportData as EeatReport;
const reportError = '';

const inventory = report?.pages ?? [];
const summary = report?.summary ?? defaultSummary;

const pageTypeName: Record<PageType, string> = {
  'state-overview': '州总览',
  'state-real-id': '州 REAL ID',
  topic: '专题',
  directory: '目录',
  collection: '索引',
  trust: '信任页',
};

const pageStatusLabel: Record<ReviewStatus, string> = {
  'human-approved': '人工复核完成',
  'ai-assisted': '来源已核对',
  'source-mapped': '来源已登记',
  pending: '等待复核',
  invalid: '需要处理',
  'not-required': '无需复核',
};

const riskLabel: Record<Risk, string> = {
  standard: '标准',
  medium: '中等',
  high: '高风险',
  policy: '政策',
};

function formatTitle(page: EeatPage) {
  if (page.pageType === 'state-overview' || page.pageType === 'state-real-id') {
    const stateId = page.route.split('/')[2];
    const state = stateById.get(stateId);
    if (state) {
      return `${state.nameZh} ${page.pageType === 'state-real-id' ? '州 REAL ID 页面' : '州办事页面'}`;
    }
  }

  if (page.pageType === 'topic') {
    const slug = page.route.split('/')[2];
    const topic = topicBySlug.get(slug);
    if (topic) return topic.title;
  }

  if (page.pageType === 'directory') {
    return `/directories/ 下的 ${page.route.replace('/directories/', '').replace('/', '')}`;
  }

  if (page.route === '/') return '首页';
  if (page.route === '/states/') return '州指南索引';
  if (page.route === '/topics/') return '专题索引';
  if (page.route === '/directories/') return '官方入口表索引';
  if (page.route === '/about/') return '关于我们';
  if (page.route === '/privacy/') return '隐私政策';
  if (page.route === '/terms/') return '服务条款';
  if (page.route === '/contact/') return '联系页';

  return page.route;
}

const qualityChecks = [
  '官方来源可追溯',
  '三类日期完整显示',
  '费用、期限等重要信息在正文旁标出政府来源',
  '页面回答一个明确的办事问题',
  '每页写明整理人和核对日期',
  '高风险事实有风险边界',
  '页面结构可抓取（h1、canonical、JSON-LD）',
];

const blockedPages = inventory.filter((page) => page.blockers.length > 0 || page.critical.length > 0);
const highRiskPending = inventory.filter((page) => page.risk === 'high' && page.reviewStatus !== 'human-approved');
const lowScorePages = inventory.filter((page) => page.score < 90);
const weakIntentPages = inventory.filter(
  (page) => (page.pageType === 'collection' || page.pageType === 'directory') && !page.signals.authorLink,
);

const officialSourceCount = new Set([
  ...federalSources.map((source) => source.url),
  ...states.flatMap((state) => [
    state.agencyUrl,
    ...state.sources.map((source) => source.url),
    ...state.actionLinks.map((link) => link.url),
  ]),
  ...topics.flatMap((topic) => topic.sources.map((source) => source.url)),
]).size;

const byType = Object.fromEntries(
  ['collection', 'state-overview', 'state-real-id', 'topic', 'directory', 'trust'].map((type) => [type, 0]),
);
const byRisk = { standard: 0, medium: 0, high: 0, policy: 0 };
for (const page of inventory) {
  byType[page.pageType] += 1;
  byRisk[page.risk] += 1;
}

const watchStates = states.filter((state) => ['watch', 'risk'].includes(getStatePublicStatus(state).tone));
const highPriorityStates = watchStates.slice(0, 6);
const weakStatePages = lowScorePages
  .filter((page) => ['state-overview', 'state-real-id'].includes(page.pageType))
  .slice(0, 10)
  .map((page) => formatTitle(page));

const plan = [
  {
    title: '第 1-2 周',
    goal: '复查搜索展现最高的页面',
    intent: '根据 Search Console 数据补强标题、开头答案和内部链接',
    sources: ['Search Console 导出', '页面已有政府来源', '州政府最近更新'],
    scope: ['优先处理已有展现但点击率偏低的州页和专题页', '核对最近 30 天出现的新搜索问题'],
    publish: toIsoDate(14),
    reviewCycle: '每周查看数据，修改后 5 个工作日抽查',
  },
  {
    title: '第 3-4 周',
    goal: '让需要改善的州页更容易使用',
    intent: '讲清州总览与 REAL ID 页面各自解决什么问题',
    sources: ['州官方主页、州DMV办理页、州文书说明页'],
    scope: weakStatePages,
    publish: toIsoDate(28),
    reviewCycle: '每 2 周复查一次',
  },
  {
    title: '第 5-6 周',
    goal: '根据热门问题扩充专题',
    intent: '补充读者最常遇到的失败原因和不能混用的规则',
    sources: ['专题官方来源 + FAQ', '州入口页'],
    scope: ['费用和时效', '外国驾照互惠', 'non citizen / lawful presence', '车辆登记 hold', '驾驶记录与扣分'],
    publish: toIsoDate(42),
    reviewCycle: '按 Search Console 流量与失败反馈复核',
  },
  {
    title: '第 7-12 周',
    goal: '形成固定的月度更新节奏',
    intent: '按照读者搜索需求和政府规则变化安排先后顺序',
    sources: ['Search Console 导出', '州政府官方更新提示页'],
    scope: [
      `优先州：${highPriorityStates.map((state) => state.nameZh).join('、')}`,
      `高优先专题：${topics
        .filter((topic) => HIGH_RISK_TOPIC_SLUGS.has(topic.slug))
        .map((topic) => topic.title)
        .slice(0, 10)
        .join('、')}`,
    ],
    publish: toIsoDate(84),
    reviewCycle: '月末复盘，下一月发布前复核',
  },
];

const qualityWorkflow = [
  {
    title: '来源优先',
    text: '先读联邦和州政府页面，再整理中文说明。每项重要要求都保留可核对的出处。',
    Icon: ShieldCheck,
  },
  {
    title: '重要信息有出处',
    text: '费用、期限、身份和资格等重要要求直接标出政府来源，不能只在页尾堆放链接。',
    Icon: Search,
  },
  {
    title: '解决具体问题',
    text: '每篇都要讲清该怎么判断、准备什么、按什么顺序办理，以及遇到问题去哪里确认。',
    Icon: Target,
  },
  {
    title: '上线检查',
    text: '缺少署名、日期或关键来源的页面不会上线；高风险内容还要先完成人工复核。',
    Icon: Flag,
  },
];

const qualityWorkbook = qualityWorkbookData as WorkbookReport;
const qualityWorkbookError = '';

const searchConsolePlan = searchConsolePlanData as SearchConsoleReport;
const searchConsolePlanError = '';

const reviewTaskList = qualityWorkbook?.queues?.humanSignoff ?? [];
const blockedWorklist = qualityWorkbook?.queues?.blocked ?? [];

const scActionList = searchConsolePlan?.prioritized ?? [];
const scPlanList = [...scActionList].slice(0, 20);

const scActionLabel: Record<string, string> = {
  'improve-title': '补标题/描述',
  'improve-answer': '补答案章节',
  'refresh-rule-change': '规则变更复核',
  'new-topic': '评估是否拆新专题',
  observe: '观察',
};
---

<BaseLayout
  title="内容质量与更新记录"
  description="查看 DMV中文办事库的页面覆盖、来源核对、人工复核、更新日期和未来 90 天内容计划。"
  publishedAt={SITE_LAUNCH_DATE}
  modifiedAt={QUALITY_MODIFIED_AT}
  reviewedAt={QUALITY_REVIEWED_AT}
>
  <section class="page-hero">
    <div class="section">
      <nav class="breadcrumbs" aria-label="面包屑">
        <a href="/">首页</a><span>/</span><span>来源与更新</span>
      </nav>
      <p class="eyebrow">来源与更新</p>
      <h1>内容质量与更新记录</h1>
      <p class="lead">这里公开本站覆盖了哪些内容、何时核对、哪些页面经过人工复核，以及接下来准备更新什么。</p>
      <div class="article-meta">
        <ContentMeta publishedAt={SITE_LAUNCH_DATE} modifiedAt={QUALITY_MODIFIED_AT} reviewedAt={QUALITY_REVIEWED_AT} />
      </div>
      {reportError ? <p class="status-chip ready" role="status">{reportError}</p> : null}
      <div class="registry-summary">
        <div>
          <strong>{states.length}</strong>
          <span>覆盖州</span>
        </div>
        <div>
          <strong>{topics.length}</strong>
          <span>跨州专题</span>
        </div>
        <div>
          <strong>{officialSourceCount}</strong>
          <span>政府来源链接</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    {report ? (
      <>
        <div class="registry-summary eeat-summary" aria-label="内容概览">
          <div>
            <strong>{summary.pages}</strong>
            <span>已检查页面</span>
          </div>
          <div>
            <strong>{summary.indexablePages}</strong>
            <span>当前可索引</span>
          </div>
          <div>
            <strong>{summary.indexablePassed}</strong>
            <span>质量检查通过</span>
          </div>
          <div>
            <strong>{summary.averageScore}</strong>
            <span>平均质量分</span>
          </div>
          <div>
            <strong>{summary.highRiskHumanApprovalPending}</strong>
            <span>等待人工复核</span>
          </div>
          <div>
            <strong>{(summary.indexablePassed / Math.max(summary.indexablePages, 1) * 100).toFixed(1)}%</strong>
            <span>质量检查通过率</span>
          </div>
        </div>

        <div class="grid two">
          <article class="card">
            <div class="card-top"><FileCheck2 size={22} aria-hidden="true" /><span class="small-badge">内容分布</span></div>
            <h2>按页类型分布</h2>
            <p>州总览 {byType['state-overview']} / REAL ID {byType['state-real-id']} / 专题 {byType.topic} / 目录 {byType.directory} / 索引 {byType.collection} / 信任页 {byType.trust}。</p>
          </article>

          <article class="card">
            <div class="card-top"><CircleCheck size={22} aria-hidden="true" /><span class="small-badge">复核状态</span></div>
            <h2>人工复核与来源核对</h2>
            <p>人工复核 <strong>{summary.humanApprovedReviews}</strong> 页；其余 <strong>{summary.aiAssistedReviews + summary.sourceMappedReviews}</strong> 页已完成来源或页面结构核对；等待复核 <strong>{summary.highRiskHumanApprovalPending}</strong> 页。</p>
          </article>

          <article class="card">
            <div class="card-top"><UserRoundCheck size={22} aria-hidden="true" /><span class="small-badge">风险结构</span></div>
            <h2>内容风险级别</h2>
            <p>标准 {byRisk.standard} 页，中等 {byRisk.medium} 页，高风险 {byRisk.high} 页，政策页 {byRisk.policy} 页。</p>
          </article>

          <article class="card">
            <div class="card-top"><CalendarCheck2 size={22} aria-hidden="true" /><span class="small-badge">复核机制</span></div>
            <h2>三日期规则</h2>
            <p>每篇必须显示“首次发布 / 内容更新 / 事实核对”。“内容更新”与“事实核对”不可混用。</p>
          </article>
        </div>

        <section class="panel">
          <h2>每页都要通过的检查</h2>
          <ol class="step-list">
            {qualityChecks.map((step) => <li>{step}</li>)}
          </ol>
        </section>

        <section class="panel">
          <h2>高风险页面复核状态</h2>
          {highRiskPending.length > 0 ? (
            <>
              <p>还有 <strong>{highRiskPending.length}</strong> 页等待人工复核。这些页面暂不进入 sitemap，也不会请求搜索引擎收录。</p>
              <div class="eeat-table-wrap">
                <table class="eeat-table">
                  <thead>
                    <tr>
                      <th>页面</th>
                      <th>风险</th>
                      <th>状态</th>
                      <th>最近核对</th>
                      <th>来源</th>
                    </tr>
                  </thead>
                  <tbody>
                    {highRiskPending.map((page) => (
                      <tr>
                        <td><a href={page.route}>{formatTitle(page)}</a></td>
                        <td><span class="status-chip warn">{riskLabel[page.risk]}</span></td>
                        <td><span class="status-chip">{pageStatusLabel[page.reviewStatus]}</span></td>
                        <td>{page.semanticReview?.reviewedAt ?? '—'}</td>
                        <td>{page.signals.hasInlineStateEvidence || page.signals.hasInlineDirectoryEvidence ? '关键要求有对应来源' : '页面来源已登记'}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </>
          ) : <p>当前所有高风险页面都已完成站长人工复核，并保留审核日期和范围。</p>}
        </section>

        <section class="panel">
          <h2>近期复核安排</h2>
          <p>{qualityWorkbookError ? qualityWorkbookError : `工作清单更新于 ${qualityWorkbook?.generatedAt?.slice(0, 10) ?? 'N/A'}。`}</p>
          <div class="eeat-table-wrap">
            <table class="eeat-table">
              <thead>
                <tr>
                  <th>页面</th>
                  <th>优先级</th>
                  <th>风险</th>
                  <th>分数</th>
                  <th>建议动作</th>
                  <th>截止</th>
                </tr>
              </thead>
              <tbody>
                {reviewTaskList.length
                  ? reviewTaskList.slice(0, 10).map((task) => (
                      <tr>
                        <td><a href={task.route}>{task.route}</a></td>
                        <td>{task.priority}</td>
                        <td><span class="status-chip warn">{riskLabel[(task.risk as Risk) ?? 'high']}</span></td>
                        <td>{task.score}</td>
                        <td>{task.actionMethod ?? task.action ?? '安排人工核对'}</td>
                        <td>{task.reviewDue ?? '—'}</td>
                      </tr>
                    ))
                  : <tr><td colspan="6">当前没有等待人工复核的高风险页面。</td></tr>}
              </tbody>
            </table>
          </div>
          <p class="small-note">今后新增或大幅改写高风险页面时，会先安排人工复核，完成后再请求搜索引擎收录。</p>
        </section>

        <div class="quality-grid-2">
          <section class="panel">
            <h2>需要继续改善的页面</h2>
            <p>评分低于 90 的页面会优先补充明确答案、实用步骤和正文旁的政府来源。</p>
            <div class="registry-table state-registry" role="list">
              {lowScorePages.map((page) => (
                <article class="registry-row" role="listitem">
                  <a class="registry-main" href={page.route}>
                    <span class={page.score >= 90 ? 'status-chip ready' : 'status-chip warn'}>{page.score}</span>
                    <span>
                      <strong>{formatTitle(page)}</strong>
                      <small>{page.route}</small>
                    </span>
                  </a>
                  <div class="registry-copy">
                    <p>{page.critical.length ? page.critical[0] : '建议补充判定路径、材料与官方入口绑定。'}</p>
                    <small>{pageTypeName[page.pageType]} · {riskLabel[page.risk]} · {pageStatusLabel[page.reviewStatus]}</small>
                  </div>
                  <div class="registry-status">
                    <span class="status-chip ready">待优化</span>
                  </div>
                  <div class="registry-actions">
                    <a href={EDITORIAL_LINKS.corrections}>复核</a>
                  </div>
                </article>
              ))}
            </div>
          </section>

          <section class="panel">
            <h2>重复内容检查</h2>
            <ul class="check-list">
              {weakIntentPages.length > 0
                ? weakIntentPages.map((page) => (
                    <li>
                      <a href={page.route}>{formatTitle(page)}</a>
                      <small>检查它是否与现有专题重复；如果不能单独解决一个问题，就合并或暂不收录。</small>
                </li>
                  ))
                : <li>当前未发现明显重复意图冲突项。索引页与详情页分工清晰。</li>}
            </ul>
          </section>

          <section class="panel">
            <h2>按搜索数据安排更新</h2>
            <p>
              {searchConsolePlanError
                ? searchConsolePlanError
                : searchConsolePlan?.includedRows
                  ? `已读取 Search Console 导出数据 ${searchConsolePlan.includedRows}/${searchConsolePlan.totalRows} 条。`
                  : '本月还没有导入新的 Search Console 查询数据。'}
            </p>
            <ul class="check-list">
              {scPlanList.length > 0
                ? scPlanList.slice(0, 10).map((item) => (
                    <li>
                      <a href={item.route}>{item.route}</a> · <strong>{scActionLabel[item.action] ?? item.action}</strong>
                      <small>
                        （展现 {item.impressionsCurrent} / 点击 {item.clicksCurrent} / 位置 {item.positionCurrent.toFixed(1)} / 展现变化
                        {item.impressionsDelta.toFixed(1)}%）
                      </small>
                      <p>{item.reason}</p>
                    </li>
                  ))
                : <li>导入 Search Console 查询数据后，这里会列出本月最值得更新的页面。</li>}
            </ul>
          </section>
        </div>

        <section class="panel">
          <h2>90 天内容与复核计划</h2>
          <div class="timeline">
            {plan.map((phase) => (
              <article class="timeline-step">
                <h3><CircleAlert size={17} aria-hidden="true" /> {phase.title}</h3>
                <p><strong>目标：</strong>{phase.goal}</p>
                <p><strong>搜索意图：</strong>{phase.intent}</p>
                <p><strong>官方来源：</strong>{phase.sources.join(' / ')}</p>
                <p><strong>范围：</strong>{phase.scope.length ? phase.scope.join('；') : '根据实际搜索问题安排'}</p>
                <p><strong>目标上线：</strong>{phase.publish}；<strong>复核：</strong>{phase.reviewCycle}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="panel">
          <h2>编辑工作流程</h2>
          <div class="grid two">
            {qualityWorkflow.map((step) => (
              <article class="card">
                <div class="card-top"><step.Icon size={22} aria-hidden="true" /><span class="small-badge">流程</span></div>
                <h2>{step.title}</h2>
                <p>{step.text}</p>
              </article>
            ))}
          </div>
          <div class="policy-links">
            <a href={EDITORIAL_LINKS.policy}>编辑政策 <ArrowRight size={15} aria-hidden="true" /></a>
            <a href={EDITORIAL_LINKS.ai}>工具使用说明 <ArrowRight size={15} aria-hidden="true" /></a>
            <a href={EDITORIAL_LINKS.corrections}>纠错政策 <ArrowRight size={15} aria-hidden="true" /></a>
            <a href={EDITORIAL_LINKS.updates}>更新记录 <ArrowRight size={15} aria-hidden="true" /></a>
            <a href="/sources/">来源清单 <ArrowRight size={15} aria-hidden="true" /></a>
          </div>
        </section>

        <section class="panel">
          <h2>需要处理的问题</h2>
          <div class="eeat-check-list">
            {blockedPages.length > 0 ? (
              blockedPages.map((page) => (
                <article class="eeat-check-item">
                  <h3><CircleCheck size={17} aria-hidden="true" /> {formatTitle(page)}</h3>
                  <p><a href={page.route}>{page.route}</a></p>
                  <ul>
                    {page.blockers.concat(page.critical).map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </article>
              ))
            ) : (
              <p>当前没有需要处理的问题。</p>
            )}
          </div>
        </section>
      </>
    ) : (
      <section class="panel">
        <h2>当前无法展示质量记录</h2>
        <p>质量数据正在更新，请稍后再查看。</p>
      </section>
    )}
  </section>
</BaseLayout>
