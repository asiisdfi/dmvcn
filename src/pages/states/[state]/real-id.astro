---
import { ArrowRight, ShieldAlert } from '@lucide/astro/icons';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContentMeta from '../../../components/ContentMeta.astro';
import EditorialDisclosure from '../../../components/EditorialDisclosure.astro';
import OfficialLinkButton from '../../../components/OfficialLinkButton.astro';
import SourceList from '../../../components/SourceList.astro';
import StateEvidenceList from '../../../components/StateEvidenceList.astro';
import {
  SITE,
  federalSources,
  getStatePublicStatus,
  states,
  topics,
  uniqueSources,
  type StateGuide,
} from '../../../data/content';
import { EDITORIAL_AUTHOR } from '../../../data/editorial';
import { buildStateEvidence, getStatePageModifiedAt } from '../../../data/state-evidence';

export function getStaticPaths() {
  return states.map((state) => ({
    params: { state: state.id },
    props: { state },
  }));
}

const { state } = Astro.props as { state: StateGuide };
const relatedTopics = topics.filter((topic) => state.relatedTopicSlugs.includes(topic.slug));
const realIdCredentialMode =
  state.realIdCredentialMode ?? (state.allCredentialsRealId ? 'all-current-real-id' : undefined);
const allCredentialsRealId = realIdCredentialMode === 'all-current-real-id';
const singleCompliantCard = realIdCredentialMode === 'single-compliant-card';
const realIdSource =
  state.actionLinks.find((link) => /real\s*id/i.test(`${link.label} ${link.description}`)) ??
  state.actionLinks[0]!;
const accessStatus = state.accessStatus ? getStatePublicStatus(state) : undefined;
const title = `${state.nameZh} REAL ID 中文材料清单`;
const description = `${state.nameZh} REAL ID 中文清单：材料类别、办理顺序、常见错误和官方来源。`;
const officialSources = uniqueSources([...state.sources, ...federalSources]);
const stateEvidence = buildStateEvidence(state, 'real-id');
const modifiedAt = getStatePageModifiedAt(state);
const realIdEvidence = stateEvidence.filter((item) => item.field === 'realIdSummary');
const documentEvidence = stateEvidence.filter((item) => item.field === 'documentHighlights');
const stepEvidence = stateEvidence.filter((item) => item.field === 'recommendedSteps');
const mistakeEvidence = stateEvidence.filter((item) => item.field === 'commonMistakes');
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const realIdDecisions = [
  {
    number: '01',
    title: allCredentialsRealId
      ? '先看现有证件'
      : singleCompliantCard
        ? '先选哪张证件'
        : '先判断是否需要',
    text: allCredentialsRealId
      ? `${state.nameZh} 当前签发的驾照和 ID 已全部合规；先看卡面星标和签发年代。`
      : singleCompliantCard
        ? `${state.nameZh} 只允许一张 REAL ID-compliant credential；先决定星标放在 driver license 还是 State ID 上。`
        : '如果你有有效护照或其他 TSA 接受证件，国内航班不一定必须急着升级州证件。',
    href: allCredentialsRealId
      ? '#real-id-evidence-heading'
      : singleCompliantCard
        ? '#credential-comparison'
        : '/topics/airport-travel-after-real-id/',
    action: allCredentialsRealId
      ? '看本州判断'
      : singleCompliantCard
        ? '比较两条路线'
        : '看机场证件',
    external: false,
  },
  {
    number: '02',
    title: '再核对材料',
    text: `把 ${state.nameZh} 的身份、SSN、地址和姓名文件放到同一个材料夹里，按官方清单逐项确认。`,
    href: '#materials',
    action: '跳到材料',
    external: false,
  },
  {
    number: '03',
    title: '最后打开官方入口',
    text: accessStatus
      ? '如果州 DMV 深层页被安全系统拦截，先从 USA.gov 州机动车目录进入对应州官方入口。'
      : `从 ${realIdSource.label} 开始，确认预约、费用、原件和是否接受线上预审。`,
    href: accessStatus?.fallbackUrl ?? realIdSource.url,
    action: accessStatus ? '打开备用目录' : '打开官方入口',
    external: true,
  },
];
const realIdAudience = allCredentialsRealId
  ? [
      '你持有当前的 Wyoming 驾照或 ID，想确认星标和联邦用途。',
      '你持有 2010 年 1 月 1 日前签发的旧 ID card，需要判断是否续期。',
      '你准备首次申请、续期或补证，需要按当前材料表整理文件。',
    ]
  : singleCompliantCard
    ? [
        `你同时考虑 ${state.nameZh} driver license 和 State ID，需要决定哪一张作为唯一星标证件。`,
        '你已经持有星标 State ID，但还需要驾驶，想判断 Limited Purpose Driver License 是否适用。',
        '你准备首证、续期或补证，需要按当前材料表和所在县的 transaction page 整理文件。',
      ]
    : [
        '你的驾照或 ID 没有 REAL ID 合规标记，且你想用州证件坐国内航班。',
        '你没有护照，或不想每次国内旅行都带护照。',
        '你准备续期、补证或搬州换证，想顺便判断是否升级 REAL ID。',
      ];
const credentialComparisonTitle = allCredentialsRealId
  ? `${state.nameZh} 当前证件和护照怎么判断`
  : singleCompliantCard
    ? '唯一 REAL ID credential 放在哪张证件上'
    : 'REAL ID、标准证件和护照怎么选';
const credentialComparisonRows = allCredentialsRealId
  ? [
      {
        label: '当前 Wyoming 驾照 / ID',
        use: 'Driver Services 当前签发的证件已全部符合 REAL ID，卡面右上角有星标。',
        material: '首次、续期或补证时仍按当前公民或非公民材料表准备，不存在另选 standard credential 的路线。',
      },
      {
        label: '2010 年前旧 ID card',
        use: '少量 2010 年 1 月 1 日前签发的 ID card 仍可能流通，州方建议续期确认合规。',
        material: '先看 Lost / Renewal 和当前材料表，再到 Driver Services 办理更新。',
      },
      {
        label: '护照或 TSA 接受证件',
        use: '有效护照等证件仍可用于 TSA 身份核验，不需要因为登机再取得第二张 Wyoming REAL ID。',
        material: '旅行证件接受范围以 TSA 官方清单为准；Wyoming 驾照业务仍按 WYDOT 要求办理。',
      },
    ]
  : singleCompliantCard
    ? [
        {
          label: `星标 ${state.nameEn} driver license`,
          use: '同时承担驾驶证件和 REAL ID 联邦身份用途；取得时要交回星标 Hawaii State ID。',
          material: `按 ${state.agency} 当前 REAL ID 材料表和所在县 transaction page 准备。`,
        },
        {
          label: '星标 State ID + Limited Purpose DL',
          use: '把 State ID 保留为唯一 REAL ID credential，再用 Limited Purpose Driver License 驾驶；后者不能用于登机或其他联邦身份用途。',
          material: 'Limited Purpose 路径不等同于普通 REAL ID 材料路线，申请前要打开所在县的专页核对身份与地址文件。',
        },
        {
          label: '护照或其他 TSA 接受证件',
          use: '已有有效旅行证件、只为国内航班核验时，不必为了旅行同时持有两张星标州证件。',
          material: '先查 TSA 接受证件清单；Hawaii 驾照或 State ID 业务仍按县级材料和预约要求办理。',
        },
      ]
    : [
        {
          label: 'REAL ID 州驾照 / ID',
          use: '适合想用州证件处理国内航班安检或部分联邦设施身份用途的人。',
          material: `按 ${state.agency} 官方清单准备身份、SSN、地址、姓名变更和 lawful presence 等材料。`,
        },
        {
          label: '标准驾照 / ID',
          use: '通常仍可用于驾驶或普通州内身份用途，但不能当作 REAL ID 联邦用途证件。',
          material: '看本州普通驾照 / ID、续期、补证或地址变更入口；不要把标准证件当作 REAL ID 使用。',
        },
        {
          label: '护照或 TSA 接受证件',
          use: '适合已经有有效护照，且只是为了国内航班身份核验的人。',
          material: '先查 TSA 接受证件列表；旅行证件规则以 TSA 官方页面为准。',
        },
      ];
const realIdFaqs = [
  {
    question: allCredentialsRealId
      ? `${state.nameZh} 还需要单独升级 REAL ID 吗？`
      : singleCompliantCard
        ? `${state.nameZh} driver license 和 State ID 能同时带星标吗？`
        : `有护照还需要办 ${state.nameZh} REAL ID 吗？`,
    answer: allCredentialsRealId
      ? '不需要另选升级路线。Wyoming Driver Services 当前签发的驾照和 ID 已全部合规；持 2010 年前旧 ID card 的人应按州方提示考虑续期。'
      : singleCompliantCard
        ? '不能。Hawaii 只允许一张 REAL ID-compliant credential；选择星标 driver license 时要交回星标 State ID，选择星标 State ID 时可另查 Limited Purpose Driver License。'
        : '不一定。有效护照等 TSA 接受证件也可用于国内航班身份核验；是否升级州证件，取决于你是否想用驾照或州 ID 处理这些用途。',
  },
  {
    question: 'REAL ID 材料可以只带复印件或手机照片吗？',
    answer: `不要这样假设。很多州要求原件或 certified copy，是否接受电子文件、预审或上传，以 ${state.agency} 官方页面为准。`,
  },
  {
    question: '中文清单和官方页面不一致怎么办？',
    answer: `以 ${state.agency} 官方页面和现场要求为准。本站用于中文理解和路径整理，不替代官方要求。`,
  },
];
const leadingSteps = [
  allCredentialsRealId
    ? '先确认现有 Wyoming card 是否为当前星标证件；2010 年前旧 ID card 按州方提示考虑续期。'
    : singleCompliantCard
      ? '先决定把唯一 REAL ID credential 放在 driver license 还是 State ID；不要同时申请两张星标证件。'
      : '先判断 REAL ID 是否必要：有效护照等 TSA 接受证件也可用于国内航班身份核验。',
];
const officialActionLabel = allCredentialsRealId
  ? '查看官方 REAL ID 公告'
  : singleCompliantCard
    ? '打开官方 REAL ID 与驾照规则'
    : '打开官方 REAL ID';
const schema = [
  {
    '@type': 'Article',
    headline: title,
    description,
    mainEntityOfPage: pageUrl,
    dateModified: modifiedAt,
    datePublished: state.publishedAt,
    inLanguage: 'zh-Hans',
    isAccessibleForFree: true,
    author: {
      '@type': 'Organization',
      name: EDITORIAL_AUTHOR.name,
      url: new URL(EDITORIAL_AUTHOR.path, Astro.site).toString(),
    },
    publisher: {
      '@type': 'Organization',
      name: SITE.name,
      url: new URL('/', Astro.site).toString(),
      logo: new URL('/assets/dmvcn-logo.png', Astro.site).toString(),
    },
    about: [`${state.nameEn} REAL ID`, `${state.nameEn} DMV`, 'REAL ID documents'],
    citation: officialSources.map((source) => source.url),
  },
  {
    '@type': 'FAQPage',
    mainEntity: realIdFaqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: '首页',
        item: new URL('/', Astro.site).toString(),
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: '州指南',
        item: new URL('/states/', Astro.site).toString(),
      },
      {
        '@type': 'ListItem',
        position: 3,
        name: state.nameZh,
        item: new URL(`/states/${state.id}/`, Astro.site).toString(),
      },
      {
        '@type': 'ListItem',
        position: 4,
        name: 'REAL ID',
        item: pageUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={description}
  publishedAt={state.publishedAt}
  modifiedAt={modifiedAt}
  reviewedAt={state.reviewedAt}
  schema={schema}
>
  <section class="page-hero">
    <div class="section">
      <nav class="breadcrumbs" aria-label="面包屑">
        <a href="/">首页</a><span>/</span><a href="/states/">州指南</a><span>/</span><a href={`/states/${state.id}/`}>{state.nameZh}</a><span>/</span><span>REAL ID</span>
      </nav>
      <p class="eyebrow">{state.abbr} REAL ID</p>
      <h1>{state.nameZh} REAL ID 中文材料清单</h1>
      <p class="lead">{state.realIdSummary}</p>
      <div class="article-meta">
        <ContentMeta publishedAt={state.publishedAt} modifiedAt={modifiedAt} reviewedAt={state.reviewedAt} />
        <a href="#official-sources">查看官方来源 <ArrowRight size={15} aria-hidden="true" /></a>
      </div>
    </div>
  </section>

  <div class="content-layout">
    <article class="article-stack">
      <section class="decision-board" aria-labelledby="decision-board-title">
        <div class="route-board-head">
          <div>
            <p class="eyebrow">三步判断</p>
            <h2 id="decision-board-title">先做这三步</h2>
          </div>
          <p>REAL ID 页面最容易越看越乱。先用这三步把方向定下来。</p>
        </div>
        <div class="route-card-grid">
          {realIdDecisions.map((item) => (
            <article class="route-card compact">
              <span>{item.number}</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <a class="route-action" href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noreferrer' : undefined}>
                {item.action} <ArrowRight size={15} aria-hidden="true" />
              </a>
            </article>
          ))}
        </div>
      </section>

      <section class="panel">
        <h2>适合先看这页的人</h2>
        <ul class="check-list">
          {realIdAudience.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section class="panel fact-check-panel" aria-labelledby="real-id-evidence-heading">
        <h2 id="real-id-evidence-heading">本州 REAL ID 关键判断</h2>
        <StateEvidenceList items={realIdEvidence} ordered />
      </section>

      <section class="panel" id="credential-comparison">
        <h2>{credentialComparisonTitle}</h2>
        <div class="comparison-table" role="table" aria-label={`${state.nameZh} REAL ID 证件判断对比`}>
          <div class="comparison-row comparison-head" role="row">
            <span role="columnheader">证件路径</span>
            <span role="columnheader">适合情况</span>
            <span role="columnheader">材料判断</span>
          </div>
          {credentialComparisonRows.map((row) => (
            <div class="comparison-row" role="row">
              <strong role="cell">{row.label}</strong>
              <p role="cell">{row.use}</p>
              <p role="cell">{row.material}</p>
            </div>
          ))}
        </div>
      </section>

      {accessStatus && (
        <section class:list={['panel', 'access-panel', accessStatus.tone]}>
          <div class="access-panel-heading">
            <h2>官方入口状态</h2>
            <span class={`status-chip ${accessStatus.tone}`}>{accessStatus.label}</span>
          </div>
          <p>{accessStatus.note}</p>
          {accessStatus.fallbackUrl && (
            <div class="access-panel-actions">
              <OfficialLinkButton href={accessStatus.fallbackUrl} label={accessStatus.fallbackLabel || '备用官方入口'} />
            </div>
          )}
        </section>
      )}

      <section class="panel" id="materials">
        <h2>材料类别</h2>
        <StateEvidenceList items={documentEvidence} className="check-list" />
      </section>

      <section class="panel">
        <h2>办理顺序</h2>
        <StateEvidenceList
          items={stepEvidence}
          ordered
          className="step-list"
          leadingItems={leadingSteps}
        />
      </section>

      <section class="panel">
        <h2>常见失败原因</h2>
        <StateEvidenceList items={mistakeEvidence} className="plain-list" />
      </section>

      <section class="panel" id="official-entry">
        <h2>官方办理入口</h2>
        <div class="action-row">
          <div>
            <strong>{realIdSource.label}</strong>
            <p>{realIdSource.description}</p>
          </div>
          <OfficialLinkButton href={realIdSource.url} label={officialActionLabel} variant="primary" />
        </div>
      </section>

      <section class="panel">
        <h2>常见问题</h2>
        <div class="faq-list">
          {realIdFaqs.map((faq) => (
            <div class="faq-item">
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="notice">
        <ShieldAlert size={22} aria-hidden="true" />
        <div>
          <strong>不要只按中文页准备材料</strong>
          <p>中文说明用于理解流程和找到入口。最终文件类型、费用、预约、是否接受电子文件，都必须按 {state.agency} 官方页面确认。</p>
        </div>
      </section>

      <EditorialDisclosure />
      <SourceList sources={officialSources} />
    </article>

    <aside class="sidebar" aria-label="侧边栏">
      <div class="panel">
        <h2>{state.nameZh} 相关页</h2>
        <div class="quick-actions">
          <a class="button-link secondary" href={`/states/${state.id}/`}>返回 DMV 总览</a>
          <OfficialLinkButton href={state.agencyUrl} label={state.agency} />
        </div>
      </div>
      <div class="panel">
        <h2>延伸阅读</h2>
        <ul class="plain-list">
          {relatedTopics.map((topic) => (
            <li><a class="text-link" href={`/topics/${topic.slug}/`}>{topic.title} <ArrowRight size={15} aria-hidden="true" /></a></li>
          ))}
        </ul>
      </div>
    </aside>
  </div>
</BaseLayout>
