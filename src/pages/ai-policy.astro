---
import { ArrowRight, FileSearch, ShieldCheck, UserRoundCheck, Wrench } from '@lucide/astro/icons';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentMeta from '../components/ContentMeta.astro';
import { EDITORIAL_AUTHOR, EDITORIAL_LINKS, EDITORIAL_POLICY_DATE, EDITORIAL_POLICY_MODIFIED_DATE } from '../data/editorial';
---

<BaseLayout
  title="工具使用说明"
  description="DMV中文办事库如何使用搜索、链接检查和内容整理工具，以及这些工具不能替代什么。"
  publishedAt={EDITORIAL_POLICY_DATE}
  modifiedAt={EDITORIAL_POLICY_MODIFIED_DATE}
  reviewedAt={EDITORIAL_POLICY_MODIFIED_DATE}
>
  <section class="page-hero">
    <div class="section">
      <nav class="breadcrumbs" aria-label="面包屑"><a href="/">首页</a><span>/</span><span>工具使用说明</span></nav>
      <p class="eyebrow">内容如何整理</p>
      <h1>工具使用说明</h1>
      <p class="lead">整理过程中会使用搜索、链接检查、脚本和生成式 AI，帮助发现变化、检查结构和准备初稿。最终结论必须回到政府来源，发布、更新与纠错责任由 DMVCN 官方编辑承担。</p>
      <div class="article-meta">
        <ContentMeta publishedAt={EDITORIAL_POLICY_DATE} modifiedAt={EDITORIAL_POLICY_MODIFIED_DATE} reviewedAt={EDITORIAL_POLICY_MODIFIED_DATE} />
      </div>
    </div>
  </section>

  <section class="section policy-layout">
    <div class="article-stack">
      <section class="panel">
        <div class="policy-heading"><Wrench size={22} aria-hidden="true" /><h2>工具会用在哪里</h2></div>
        <ul class="check-list">
          <li>整理大量政府页面中的主题和入口，发现可能需要复核的差异。</li>
          <li>把已经确认的信息整理成中文清单、步骤、常见问题和对比表初稿。</li>
          <li>检查重复内容、缺少字段、内部链接、结构化数据和页面一致性。</li>
          <li>监测官方链接状态，为编辑复核提供线索。</li>
        </ul>
      </section>

      <section class="panel">
        <div class="policy-heading"><ShieldCheck size={22} aria-hidden="true" /><h2>工具不能替代什么</h2></div>
        <ul class="plain-list">
          <li>工具生成的文字、搜索摘要或自动翻译，不能单独证明费用、期限、材料或资格。</li>
          <li>任何工具都不能替用户判断移民身份、法律责任、保险责任或驾照是否有效。</li>
          <li>引用链接必须实际打开并核对；打不开或不能支持页面结论时不会保留。</li>
          <li>本站不会编造作者、专业资历、采访、案例、用户评价或亲身办理经历。</li>
        </ul>
      </section>

      <section class="panel">
        <div class="policy-heading"><FileSearch size={22} aria-hidden="true" /><h2>发布前检查</h2></div>
        <ol class="step-list">
          <li>关键事实必须落到政府官方 URL。</li>
          <li>中文表述必须与来源的适用范围一致。</li>
          <li>高风险结论要在正文旁标出出处，并写清适用范围和不确定之处。</li>
          <li>页面上线前检查内容、搜索信息、链接、结构和日期。</li>
          <li>涉及身份、资格、费用和法律后果的页面，还要由真实人员对照来源复查并留下记录。</li>
        </ol>
      </section>

      <section class="notice">
        <UserRoundCheck size={22} aria-hidden="true" />
        <div>
          <strong>责任不会交给工具</strong>
          <p>{`${EDITORIAL_AUTHOR.name} 对发布内容、纠错和更新负责。程序检查与人工复核分开记录，工具检查不会被写成人工审核或专业审核。`}</p>
        </div>
      </section>

      <nav class="policy-links" aria-label="相关政策">
        <a href={EDITORIAL_LINKS.policy}>编辑政策 <ArrowRight size={15} aria-hidden="true" /></a>
        <a href={EDITORIAL_AUTHOR.path}>编辑介绍 <ArrowRight size={15} aria-hidden="true" /></a>
      </nav>
    </div>
  </section>
</BaseLayout>
