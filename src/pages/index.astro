---
import { ArrowRight, CalendarDays, ClipboardList, ExternalLink, FileCheck2, MapPinned, Search, ShieldAlert } from '@lucide/astro/icons';
import BaseLayout from '../layouts/BaseLayout.astro';
import { REVIEW_DATE, SITE, getStatePublicStatus, states, topics } from '../data/content';

const directoryPages = 13;
const pageCount = states.length * 2 + topics.length + directoryPages;
const fallbackStates = states.filter((state) => ['watch', 'risk'].includes(getStatePublicStatus(state).tone));
const fallbackPreview = fallbackStates.slice(0, 12).map((state) => state.abbr).join(' / ');
const launchTasks = [
  {
    label: '登机要用驾照',
    detail: '先看 TSA 接受证件；有护照的人不一定要急着办 REAL ID。',
    href: '/topics/airport-travel-after-real-id/',
  },
  {
    label: '只办州 ID',
    detail: '不考驾照时，分清 State ID、non-driver ID、REAL ID ID card、Enhanced ID 和 mobile ID。',
    href: '/topics/state-id-non-driver-id-real-id-card/',
  },
  {
    label: '搬家后要续期',
    detail: '先处理 DMV 地址，再判断续期、补证或线上资格。',
    href: '/topics/renewal-replacement-address/',
  },
  {
    label: '驾照 / ID 丢了',
    detail: '先分清普通补证、被盗报案、identity theft、地址更新、REAL ID 和临时旅行风险。',
    href: '/topics/lost-stolen-license-id-replacement-identity-theft/',
  },
  {
    label: '要不要去 DMV',
    detail: '先判断线上、kiosk、邮寄、预约或现场核验路径。',
    href: '/topics/online-office-appointment/',
  },
  {
    label: '诈骗短信 / 假官网',
    detail: '收到 DMV、toll、ticket、REAL ID 付款短信或加急广告时，先核验官方入口。',
    href: '/topics/dmv-scam-text-fake-ticket-toll-real-id-phishing/',
  },
  {
    label: '费用和多久拿证',
    detail: '查服务费、付款方式、临时凭证、邮寄时间和旅行风险。',
    href: '/topics/dmv-fees-mailing-temporary-license/',
  },
  {
    label: '罚单 / toll / hold',
    detail: '续期或登记被卡住时，先分清 DMV、法院、toll、保险或地方机构。',
    href: '/topics/tickets-tolls-insurance-lapse-registration-hold/',
  },
  {
    label: '驾照记录 / 扣分',
    detail: '查 driving record、points、traffic school、driver improvement、保险和雇主 MVR 前先看这里。',
    href: '/topics/driving-record-points-traffic-school/',
  },
  {
    label: '恢复驾照',
    detail: '驾照被 suspend 或 revoke 后，先查 status、clearance、SR-22/FR-44、课程和恢复费。',
    href: '/topics/driver-license-suspension-reinstatement-sr22/',
  },
  {
    label: '残疾停车牌',
    detail: '申请 placard、disabled plates、临时停车证、续期、补证和跨州使用前先看这里。',
    href: '/topics/disabled-parking-placard-plates/',
  },
  {
    label: '刚搬到新州',
    detail: '看新居民期限、外州驾照转入、车辆登记和保险顺序。',
    href: '/topics/moving-to-new-state/',
  },
  {
    label: '车辆登记 / 车牌',
    detail: '买车或搬州后，先排 title、registration、保险、车检和旧州退牌。',
    href: '/topics/vehicle-title-registration-insurance-after-move/',
  },
  {
    label: '车辆 registration 续期',
    detail: '过期、没收到 notice 或线上被卡时，先查地址、保险、车检、hold 和停驶路径。',
    href: '/topics/vehicle-registration-renewal-expired-tags-non-operation/',
  },
  {
    label: '车牌 / sticker 丢了',
    detail: '先分清 plate、registration card、sticker/decal/tab、被盗报案、换号和 toll/保险 hold。',
    href: '/topics/lost-stolen-license-plates-registration-card-sticker/',
  },
  {
    label: '临时牌照 / trip permit',
    detail: '买车、跨州开回家、没收到正式牌或登记未完成时，先分清 dealer tag、trip permit 和 registration。',
    href: '/topics/temporary-tag-trip-permit-dealer-plate/',
  },
  {
    label: '买二手车查 title',
    detail: '付款前先核对 VIN、title、lien、salvage/flood、odometer 和卖家姓名。',
    href: '/topics/used-car-title-lien-salvage-odometer-check/',
  },
  {
    label: '车辆 title 丢了',
    detail: '先查最后签发州、record owner、地址、lien 和 electronic title，再申请 replacement。',
    href: '/topics/lost-vehicle-title-replacement-electronic-title-lien-sale/',
  },
  {
    label: '赠车 / 继承车',
    detail: '亲属赠车、车主去世、TOD beneficiary、estate 和 lien 场景先分清 title 路径。',
    href: '/topics/gift-inherited-vehicle-title-transfer/',
  },
  {
    label: '车检 / 排放',
    detail: '续 registration 前先确认 safety inspection、smog/emissions、VIN check 和 county 规则。',
    href: '/topics/vehicle-inspection-emissions-smog-vin-check/',
  },
  {
    label: '卖车 / 退牌',
    detail: '卖车、捐车或报废后，先做责任解除、退牌和保险收尾。',
    href: '/topics/sold-car-release-liability-plates-insurance/',
  },
  {
    label: '没有自己账单',
    detail: '住亲友家、宿舍、sublease 或只有 P.O. Box 时，先查地址证明替代路径。',
    href: '/topics/residency-proof-no-bills-po-box/',
  },
  {
    label: '第一次考驾照',
    detail: '按 permit、笔试、练车、路考和车辆要求排顺序。',
    href: '/topics/first-driver-license-road-test/',
  },
  {
    label: '路考当天',
    detail: '核对 permit、陪同人、registration、insurance、车辆预检、租车合同和重考规则。',
    href: '/topics/road-test-day-vehicle-sponsor-insurance-rental-retest/',
  },
  {
    label: '青少年驾照',
    detail: '未满 18 岁先查 parent consent、driver education、练车小时、GDL 和夜间/乘客限制。',
    href: '/topics/teen-driver-permit-gdl-parent-guide/',
  },
  {
    label: '高龄驾驶',
    detail: '长辈续驾照、视力测试、medical review 或家属担心 unsafe driver 时先看官方路径。',
    href: '/topics/older-driver-license-renewal-medical-review/',
  },
  {
    label: '中文笔试 / 翻译',
    detail: '分清中文笔试、口译、手册、CDL 限制和文件翻译。',
    href: '/topics/dmv-test-language-translation-interpreter/',
  },
  {
    label: '外国驾照 / IDP',
    detail: '先判断访客、居民、IDP 翻译、互惠免考和换州驾照路径。',
    href: '/topics/foreign-license-idp-transfer/',
  },
  {
    label: '学生 / 非居民',
    detail: '留学生、访问学者或短期工作者，先分清 resident、visitor、temporary visitor 和车辆登记。',
    href: '/topics/student-temporary-resident-license-registration/',
  },
  {
    label: '非公民材料',
    detail: '按 lawful presence 或身份类别入口准备，不套用公民清单。',
    href: '/topics/non-citizen-license-id/',
  },
  {
    label: '不能办 REAL ID',
    detail: '分清 standard license、AB 60、drive-only、DPC 和联邦用途限制。',
    href: '/topics/standard-license-driving-privilege-no-lawful-status/',
  },
];
const directoryTasks = [
  {
    label: '50 州 REAL ID 入口',
    detail: '按州直接打开 REAL ID / Star Card / Travel ID 官方页面。',
    href: '/directories/real-id/',
  },
  {
    label: 'DMV 常用业务入口',
    detail: '续期、补证、地址变更、预约和线上服务放到同一张表。',
    href: '/directories/dmv-services/',
  },
  {
    label: '线上/现场分流表',
    detail: '先判断能否线上开始、是否要办公室核验或预约。',
    href: '/directories/service-paths/',
  },
  {
    label: '预约和办公室入口表',
    detail: '按州查预约入口、办公室类型、REAL ID Center 和 walk-in 提醒。',
    href: '/directories/appointments/',
  },
  {
    label: '笔试、路考和 learner permit',
    detail: '第一次考驾照时，先查 permit、knowledge test、road test 和第三方考点。',
    href: '/directories/tests-permits/',
  },
  {
    label: '考试语言、翻译和口译',
    detail: '先查是否有中文/多语言笔试、文件翻译、口译或 English-only 限制。',
    href: '/directories/language-access/',
  },
  {
    label: '费用和拿证时间表',
    detail: '付款方式、服务费、临时凭证、邮寄卡片和处理时间。',
    href: '/directories/costs-timing/',
  },
  {
    label: 'SSN / 身份类别分流表',
    detail: '没有 SSN、ITIN、lawful presence、非公民或临时访客先看这里。',
    href: '/directories/identity-ssn/',
  },
  {
    label: '搬到新州后先办什么',
    detail: '新居民、外州驾照转入、地址更新和车辆登记顺序入口。',
    href: '/directories/new-residents/',
  },
  {
    label: '外国/外州驾照转入和 IDP',
    detail: '外国驾照、外州换证、国际驾驶许可、互惠免考和翻译/交旧证规则。',
    href: '/directories/foreign-license/',
  },
  {
    label: 'DMV 材料规则表',
    detail: '地址证明、SSN、姓名链条、原件/认证副本和 P.O. Box 规则。',
    href: '/directories/document-rules/',
  },
  {
    label: 'DMV 期限提醒表',
    detail: '地址变更、搬州、续期和材料时效里的关键天数。',
    href: '/directories/deadlines/',
  },
  {
    label: '官方来源库',
    detail: '查看本站引用过的联邦、州政府和官方办理入口。',
    href: '/sources/',
  },
  {
    label: '维护台账',
    detail: '看覆盖范围、核对日期、官方 URL 和链接使用说明。',
    href: '/quality/',
  },
];
---

<BaseLayout title="美国 DMV / REAL ID 中文办事信息库" description={SITE.description} updatedAt={REVIEW_DATE}>
  <section class="hero">
    <div class="hero-inner desk-grid">
      <div class="hero-copy">
        <p class="eyebrow">DMV 办事台账</p>
        <h1>选州，直达官方入口</h1>
        <p class="lead">
          短句、清单、官方链接。先用中文确认路线，最后回到 DMV / DPS / RMV / MVC 官方系统办理。
        </p>
        <div class="hero-stats" aria-label="站点概况">
          <span class="stat-pill"><MapPinned size={17} aria-hidden="true" />{states.length} 个州</span>
          <span class="stat-pill"><FileCheck2 size={17} aria-hidden="true" />{pageCount} 页资料</span>
          <span class="stat-pill"><CalendarDays size={17} aria-hidden="true" />核对到 {REVIEW_DATE}</span>
        </div>
        <form class="finder" data-finder>
          <div class="field">
            <label for="state-select">所在州</label>
            <select id="state-select" name="state">
              <option value="">先看通用专题</option>
              {states.map((state) => (
                <option value={state.id}>{state.nameZh} / {state.abbr}</option>
              ))}
            </select>
          </div>
          <div class="field">
            <label for="task-select">办理事项</label>
            <select id="task-select" name="task">
              <option value="overview">州 DMV 总览</option>
              <option value="real-id">REAL ID 州清单</option>
              {topics.map((topic) => (
                <option value={`topic:${topic.slug}`}>{topic.title}</option>
              ))}
            </select>
          </div>
          <button class="button primary" type="submit">
            <Search size={18} aria-hidden="true" />
            找入口
          </button>
        </form>
      </div>
      <aside class="counter-visual" aria-label="资料状态">
        <img
          src="/assets/dmv-guide-hero.jpg"
          alt="桌面上的文件夹、清单和手机日历"
          width="1672"
          height="941"
          fetchpriority="high"
          decoding="async"
        />
        <dl class="status-ledger">
          <div>
            <dt>州指南</dt>
            <dd>{states.length}/{states.length}</dd>
          </div>
          <div>
            <dt>专题复核</dt>
            <dd>{topics.length}/{topics.length}</dd>
          </div>
          <div>
            <dt>备用入口</dt>
            <dd title={fallbackPreview}>{fallbackStates.length ? `${fallbackStates.length} 州` : '无'}</dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <section class="section route-section">
    <div class="section-header">
      <div>
        <p class="eyebrow">先选场景</p>
        <h2>办事路径分流</h2>
        <p>多数失败不是材料少一张，而是先后顺序走错。</p>
      </div>
    </div>
    <div class="task-lanes">
      {launchTasks.map((task, index) => (
        <a class="task-lane" href={task.href}>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <strong>{task.label}</strong>
          <p>{task.detail}</p>
          <ArrowRight size={16} aria-hidden="true" />
        </a>
      ))}
    </div>
  </section>

  <section class="section compact-section">
    <div class="notice">
      <ShieldAlert size={22} aria-hidden="true" />
      <div>
        <strong>先说清楚</strong>
        <p>{SITE.disclaimer} 这里负责把官方信息拆成中文路径，不负责判断你最终能不能办成。</p>
      </div>
    </div>
  </section>

  <section class="section route-section">
    <div class="section-header">
      <div>
        <p class="eyebrow">入口查表</p>
        <h2>不想读长文，直接查入口</h2>
        <p>把 50 州常用官方入口整理成表格，适合已经知道自己要办什么的人。</p>
      </div>
      <a class="text-link" href="/directories/">查看入口表 <ArrowRight size={16} aria-hidden="true" /></a>
    </div>
    <div class="task-lanes">
      {directoryTasks.map((task, index) => (
        <a class="task-lane" href={task.href}>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <strong>{task.label}</strong>
          <p>{task.detail}</p>
          <ArrowRight size={16} aria-hidden="true" />
        </a>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">州入口</p>
        <h2>州入口台账</h2>
        <p>先从州机构进入，再看 REAL ID、地址变更、续期或预约路径。</p>
      </div>
      <a class="text-link" href="/states/">查看全部州 <ArrowRight size={16} aria-hidden="true" /></a>
    </div>
    <div class="state-table" role="list">
      {states.map((state) => (
        <article class="state-row" role="listitem">
          <a class="state-main" href={`/states/${state.id}/`}>
            <span class="state-badge">{state.abbr}</span>
            <span>
              <strong>{state.nameZh}</strong>
              <small>{state.agency}</small>
            </span>
          </a>
          <div class="state-row-note">
            <ClipboardList size={17} aria-hidden="true" />
            <span>{state.documentHighlights[0]}</span>
          </div>
          <div class="state-row-actions">
            <a href={`/states/${state.id}/`}>总览</a>
            <a href={`/states/${state.id}/real-id/`}>REAL ID</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <div>
        <p class="eyebrow">办事提醒</p>
        <h2>办事前最容易卡住的点</h2>
        <p>这些不是泛泛科普，而是整理材料时最常见的分岔口。</p>
      </div>
      <a class="text-link" href="/topics/">查看全部专题 <ArrowRight size={16} aria-hidden="true" /></a>
    </div>
    <div class="topic-strip">
      {topics.slice(0, 6).map((topic) => (
        <article class="topic-note">
          <span class="small-badge">{topic.eyebrow}</span>
          <h3>{topic.title}</h3>
          <p>{topic.description}</p>
          <a class="text-link" href={`/topics/${topic.slug}/`}>查看 <ExternalLink size={15} aria-hidden="true" /></a>
        </article>
      ))}
    </div>
  </section>

  <script>
    const finder = document.querySelector('[data-finder]');
    finder?.addEventListener('submit', (event) => {
      event.preventDefault();
      const form = event.currentTarget;
      if (!(form instanceof HTMLFormElement)) return;
      const state = String(new FormData(form).get('state') || '');
      const task = String(new FormData(form).get('task') || 'overview');

      if (task.startsWith('topic:')) {
        window.location.href = `/topics/${task.replace('topic:', '')}/`;
        return;
      }

      if (!state) {
        window.location.href = '/topics/real-id-basics/';
        return;
      }

      window.location.href = task === 'real-id' ? `/states/${state}/real-id/` : `/states/${state}/`;
    });
  </script>
</BaseLayout>
