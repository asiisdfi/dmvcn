---
import { CalendarDays, Menu, Search, X } from '@lucide/astro/icons';
import { SITE } from '../data/content';
import { EDITORIAL_AUTHOR, EDITORIAL_LINKS } from '../data/editorial';
import { isRouteIndexable } from '../data/publication-gate';
import ContentMeta from '../components/ContentMeta.astro';
import '../styles/global.css';

type JsonLd = Record<string, unknown>;

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schema?: JsonLd | JsonLd[];
  publishedAt?: string;
  modifiedAt?: string;
  reviewedAt?: string;
  showContentMeta?: boolean;
  indexable?: boolean;
};

const {
  title,
  description = SITE.description,
  canonical,
  ogImage = '/assets/dmv-guide-hero.jpg',
  schema,
  publishedAt,
  modifiedAt,
  reviewedAt,
  showContentMeta = false,
  indexable: indexableOverride,
} = Astro.props as Props;

const currentPath = Astro.url.pathname;
const indexable = indexableOverride ?? isRouteIndexable(currentPath);
const isArticle = Boolean(publishedAt || modifiedAt || reviewedAt);
const pageTitle = title ? `${title} | ${SITE.name}` : SITE.name;
const canonicalUrl = canonical
  ? new URL(canonical, Astro.site).toString()
  : new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const organizationId = new URL('/#organization', Astro.site).toString();
const authorUrl = new URL(EDITORIAL_AUTHOR.path, Astro.site).toString();
const organizationSchema: JsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': organizationId,
  name: SITE.name,
  alternateName: SITE.shortName,
  description: SITE.description,
  url: new URL('/', Astro.site).toString(),
  logo: new URL('/assets/dmvcn-logo.png', Astro.site).toString(),
  publishingPrinciples: new URL(EDITORIAL_LINKS.policy, Astro.site).toString(),
  correctionsPolicy: new URL(EDITORIAL_LINKS.corrections, Astro.site).toString(),
  ...(SITE.contactEmail ? { email: SITE.contactEmail } : {}),
};
const siteSchema: JsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  description: SITE.description,
  url: new URL('/', Astro.site).toString(),
  inLanguage: 'zh-Hans',
  publisher: {
    '@type': 'Organization',
    '@id': organizationId,
  },
};
const pageSchemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const jsonLdItems = [organizationSchema, siteSchema, ...pageSchemas].map((item) =>
  Object.prototype.hasOwnProperty.call(item, '@context')
    ? item
    : { '@context': 'https://schema.org', ...item },
);
const navItems = [
  { href: '/', label: '首页' },
  { href: '/states/', label: '州指南' },
  { href: '/topics/', label: '事项大全' },
  { href: '/practice-tests/', label: '中文笔试' },
  { href: '/directories/', label: '官方入口表' },
  { href: '/quality/', label: '来源与更新' },
];
const isCurrentNav = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<!doctype html>
<html lang="zh-Hans">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content={EDITORIAL_AUTHOR.name} />
    {!indexable && <meta name="robots" content="noindex,follow" />}
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/assets/dmvcn-logo.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/assets/dmvcn-logo.png" />
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="zh_CN" />
    {publishedAt && <meta property="article:published_time" content={publishedAt} />}
    {modifiedAt && <meta property="article:modified_time" content={modifiedAt} />}
    {modifiedAt && <meta property="og:updated_time" content={modifiedAt} />}
    {reviewedAt && <meta name="content-review-date" content={reviewedAt} />}
    {isArticle && <link rel="author" href={authorUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    {jsonLdItems.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body>
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <header class="site-header">
      <a class="brand" href="/" aria-label="回到首页">
        <img class="brand-mark" src="/assets/dmvcn-logo.png" alt="" width="36" height="36" />
        <span>
          <strong>{SITE.name}</strong>
          <small>独立中文整理，不代替政府机构</small>
        </span>
      </a>

      <button class="nav-toggle" type="button" aria-label="打开导航" aria-expanded="false" aria-controls="main-nav" data-nav-toggle>
        <Menu class="nav-open-icon" size={22} aria-hidden="true" />
        <X class="nav-close-icon" size={22} aria-hidden="true" />
      </button>

      <nav class="main-nav" id="main-nav" aria-label="主导航" data-main-nav>
        {navItems.map((item) => (
          <a href={item.href} class:list={[isCurrentNav(item.href) && 'is-current']} aria-current={isCurrentNav(item.href) ? 'page' : undefined}>
            {item.label}
          </a>
        ))}
        <a class="nav-find" href="/#finder"><Search size={16} aria-hidden="true" />查办事</a>
      </nav>
    </header>

  <main id="main-content">
    {showContentMeta && publishedAt && modifiedAt && reviewedAt ? (
      <div class="section">
        <div class="article-meta">
          <ContentMeta publishedAt={publishedAt} modifiedAt={modifiedAt} reviewedAt={reviewedAt} />
        </div>
      </div>
    ) : null}
    <slot />
  </main>

    <footer class="site-footer">
      <div class="footer-brand">
        <strong>{SITE.name}</strong>
        <p>{SITE.disclaimer}</p>
      </div>
      <nav class="footer-links" aria-label="页脚导航">
        <a href="/about/">关于</a>
        <a href={EDITORIAL_AUTHOR.path}>DMVCN 编辑</a>
        <a href={EDITORIAL_LINKS.policy}>编辑政策</a>
        <a href={EDITORIAL_LINKS.ai}>工具说明</a>
        <a href={EDITORIAL_LINKS.updates}>更新记录</a>
        <a href="/contact/">联系</a>
        <a href="/privacy/">隐私</a>
        <a href="/terms/">条款</a>
        <a href="/practice-tests/">中文笔试</a>
        <a href="/directories/">入口表</a>
        <a href="/sources/">来源</a>
      </nav>
      <p class="review-note">
        <CalendarDays size={15} aria-hidden="true" />每页保留来源和核对日期；费用、预约和材料要求请在办理前回官方页面确认。
      </p>
    </footer>

    <script>
      const navToggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
      const mainNav = document.querySelector<HTMLElement>('[data-main-nav]');

      const setNavOpen = (open: boolean) => {
        if (!navToggle || !mainNav) return;
        navToggle.setAttribute('aria-expanded', String(open));
        navToggle.setAttribute('aria-label', open ? '关闭导航' : '打开导航');
        mainNav.classList.toggle('is-open', open);
      };

      navToggle?.addEventListener('click', () => {
        setNavOpen(navToggle.getAttribute('aria-expanded') !== 'true');
      });

      mainNav?.addEventListener('click', (event) => {
        if (event.target instanceof HTMLAnchorElement) setNavOpen(false);
      });

      window.addEventListener('resize', () => {
        if (window.innerWidth > 760) setNavOpen(false);
      });
    </script>
  </body>
</html>
