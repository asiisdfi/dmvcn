{
  "name": "dmv-cn",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "audit:links": "node --experimental-strip-types scripts/audit-official-links.mjs",
    "audit:content": "node --experimental-strip-types scripts/audit-content-quality.mjs",
    "audit:eeat": "node --experimental-strip-types scripts/audit-eeat.mjs",
    "audit:eeat:strict": "EEAT_STRICT=1 node --experimental-strip-types scripts/audit-eeat.mjs",
    "audit:site": "node scripts/audit-site-integrity.mjs",
    "audit:seo": "node scripts/audit-seo.mjs",
    "audit:launch": "node --env-file-if-exists=.env scripts/audit-launch-config.mjs",
    "verify:launch": "npm run audit:content && npm run build && npm run audit:eeat && npm run audit:site && npm run audit:seo && npm run audit:launch",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@lucide/astro": "^1.23.0",
    "astro": "^7.0.6"
  },
  "devDependencies": {
    "parse5": "^8.0.1"
  }
}
